{
  "name": "reviewa",
  "displayName": "Reviewa",
  "description": "Leave in-line comments on a git diff available to your favourite coding agents to resolve",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "reviewa.createComment",
        "title": "Submit Comment"
      },
      {
        "command": "reviewa.deleteThread",
        "title": "Delete Thread",
        "icon": "$(trash)"
      },
      {
        "command": "reviewa.deleteComment",
        "title": "Delete Comment",
        "icon": "$(trash)"
      },
      {
        "command": "reviewa.editComment",
        "title": "Edit Comment",
        "icon": "$(edit)"
      },
      {
        "command": "reviewa.saveComment",
        "title": "Save Comment",
        "icon": "$(check)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "reviewa.createComment",
          "when": "false"
        },
        {
          "command": "reviewa.deleteThread",
          "when": "false"
        },
        {
          "command": "reviewa.deleteComment",
          "when": "false"
        },
        {
          "command": "reviewa.editComment",
          "when": "false"
        },
        {
          "command": "reviewa.saveComment",
          "when": "false"
        }
      ],
      "comments/commentThread/context": [
        {
          "command": "reviewa.createComment",
          "group": "inline",
          "when": "commentController == reviewa"
        }
      ],
      "comments/comment/context": [
        {
          "command": "reviewa.saveComment",
          "group": "inline",
          "when": "commentController == reviewa && comment == pending"
        }
      ],
      "comments/commentThread/title": [
        {
          "command": "reviewa.deleteThread",
          "group": "inline",
          "when": "commentController == reviewa && !commentThreadIsEmpty"
        }
      ],
      "comments/comment/title": [
        {
          "command": "reviewa.editComment",
          "group": "inline",
          "when": "commentController == reviewa && comment == pending"
        },
        {
          "command": "reviewa.deleteComment",
          "group": "inline",
          "when": "commentController == reviewa"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
